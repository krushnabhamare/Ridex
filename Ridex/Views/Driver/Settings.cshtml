@{
    Layout = "~/Views/Shared/_DriverLayout.cshtml";
    ViewData["Title"] = "Settings";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card p-4">
            <h4 class="fw-bold mb-4">Driver Settings</h4>

            <div class="d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle">
                <div>
                    <div class="fw-semibold">Online Availability</div>
                    <small class="text-secondary">Receive new ride requests</small>
                </div>
                <div class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" checked>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle">
                <div>
                    <div class="fw-semibold">Sound Alerts</div>
                    <small class="text-secondary">Play sound on new ride request</small>
                </div>
                <div class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" checked>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle">
                <div>
                    <div class="fw-semibold">Location Tracking</div>
                    <small class="text-secondary">Allow live location updates</small>
                </div>
                <div class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" checked>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center py-3">
                <div>
                    <div class="fw-semibold">Dark Mode</div>
                    <small class="text-secondary">Driver panel dark appearance</small>
                </div>
                <div class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" checked>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card p-4">
            <h5 class="fw-bold mb-3">Support</h5>
            <a href="javascript:void(0)" class="btn btn-outline-light w-100 mb-2">Help Center</a>
            <a href="javascript:void(0)" class="btn btn-outline-light w-100 mb-2">Contact Support</a>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-danger w-100">Logout</a>
        </div>
    </div>
</div>