@model List<Ridex.Models.Ride>

@{
    Layout = "~/Views/Shared/_DriverLayout.cshtml";
    ViewData["Title"] = "Ride Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

    <div>

        <h4 class="fw-bold mb-1" style="color:#fff">
            Ride Requests
        </h4>

        <small class="text-secondary">
            Accept nearby pending ride requests
        </small>

    </div>

    <a asp-action="RideRequestsMap"
       class="btn btn-outline-light btn-sm">

        <i class="fa-solid fa-map me-2"></i>

        Live Map

    </a>

</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (Model != null && Model.Any())
{
    <div class="d-flex flex-column gap-3">

        @foreach (var ride in Model)
        {
            <div class="card p-3">

                <div class="row align-items-center g-3">

                    <!-- Rider -->
                    <div class="col-lg-4">

                        <div class="d-flex align-items-center gap-3">

                            <div class="driver-avatar"
                                 style="width:48px;height:48px;font-size:14px;">

                                <i class="fa-solid fa-user"></i>

                            </div>

                            <div>

                                <div class="fw-semibold">
                                    @(ride.Rider?.FullName ?? "Rider")
                                </div>

                                <small class="text-secondary d-block">
                                    @ride.PickupLocation
                                </small>

                                <small class="text-secondary d-block">
                                    @ride.DropLocation
                                </small>

                            </div>

                        </div>

                    </div>

                    <!-- Ride ID -->
                    <div class="col-lg-2">

                        <small class="text-secondary d-block">
                            Ride Id
                        </small>

                        <span class="fw-semibold">
                            #@ride.Id
                        </span>

                    </div>

                    <!-- Fare -->
                    <div class="col-lg-2">

                        <small class="text-secondary d-block">
                            Fare
                        </small>

                        <span class="fw-bold text-warning">
                            ₹@ride.Fare
                        </span>

                    </div>

                    <!-- Status -->
                    <div class="col-lg-2 text-lg-end">

                        <span class="badge bg-warning text-dark">
                            @ride.Status
                        </span>

                    </div>

                </div>

                <!-- Actions -->
                <div class="d-flex gap-2 mt-3 flex-wrap">

                    <button type="button"
                            class="btn btn-outline-light"
                            disabled>

                        Decline

                    </button>

                    <a asp-action="AcceptRide"
                       asp-route-id="@ride.Id"
                       class="btn btn-warning flex-grow-1 accept-btn"
                       onclick="disableAccept(this)">

                        Accept Ride

                    </a>

                </div>

            </div>
        }

    </div>
}
else
{
    <div class="card p-5 text-center">

        <i class="fa-solid fa-bell-slash fa-2x mb-3 text-secondary"></i>

        <div class="fw-semibold">
            No ride requests
        </div>

        <div class="text-secondary small">
            New pending ride requests will appear here.
        </div>

    </div>
}

@section Scripts {

    <script>

        
        // Prevent Multiple Clicks
        

        function disableAccept(btn) {

            btn.classList.add("disabled");

            btn.innerText = "Accepting...";

            btn.style.pointerEvents = "none";
        }

        
        // SignalR Events
        

        if (typeof rideConnection !== "undefined") {

            // New Ride Request
            rideConnection.on(
                "ReceiveRideRequest",
                function () {

                    location.reload();
                });

            // Ride Cancelled
            rideConnection.on(
                "RideCancelled",
                function () {

                    location.reload();
                });
        }

    </script>
}