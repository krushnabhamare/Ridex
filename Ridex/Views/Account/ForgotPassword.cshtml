@model Ridex.ViewModels.ForgotPasswordViewModel

@{
    Layout = "~/Views/Shared/_LandingLayout.cshtml";

    ViewData["Title"] = "Forgot Password";
}

<style>

    .forgot-password-card {
        max-width: 450px;
    }

</style>

<div class="container py-5">

    <div class="card p-4 mx-auto shadow-sm border-0 forgot-password-card">

        <!-- ICON -->
        <div class="text-center mb-3">

            <div class="auth-form-logo mx-auto">

                <i class="fa-solid fa-lock"></i>

            </div>

        </div>

        <!-- TITLE -->
        <div class="text-center mb-4">

            <h3 class="fw-bold mb-2">

                Forgot Password

            </h3>

            <p class="text-secondary mb-0">

                Enter your email address to receive a secure password reset link.

            </p>

        </div>

        <!-- FORM -->
        <form asp-action="ForgotPassword"
              method="post"
              id="forgotPasswordForm">

            <!-- EMAIL -->
            <div class="mb-3">

                <label class="form-label fw-semibold">

                    Email Address

                </label>

                <div class="auth-input-group">

                    <i class="fa-regular fa-envelope"></i>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Enter your email"
                           autocomplete="email" />

                </div>

                <span asp-validation-for="Email"
                      class="text-danger small">
                </span>

            </div>

            <!-- SUBMIT -->
            <button type="submit"
                    class="btn btn-warning w-100 fw-semibold py-3"
                    id="forgotPasswordBtn">

                Send Reset Link

            </button>

            <!-- BACK -->
            <div class="text-center mt-3">

                <a asp-action="Login"
                   class="text-decoration-none text-secondary">

                    <i class="fa-solid fa-arrow-left me-1"></i>

                    Back to Login

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        // =============================
        // Cached Elements
        // =============================

        const forgotPasswordForm =
            document.getElementById(
                "forgotPasswordForm");

        const forgotPasswordBtn =
            document.getElementById(
                "forgotPasswordBtn");

        // =============================
        // Submit Protection
        // =============================

        forgotPasswordForm.addEventListener(
            "submit",
            function () {

                if (forgotPasswordBtn.disabled)
                    return false;

                forgotPasswordBtn.disabled = true;

                forgotPasswordBtn.innerHTML =
                    '<i class="fa-solid fa-spinner fa-spin me-2"></i>Sending Reset Link...';
            });

    </script>
}