@model List<Ridex.Models.Ride>

@{
    ViewData["Title"] = "My Rides";
    Layout = "~/Views/Shared/_RiderLayout.cshtml";
}

@functions {
    string GetRideBadge(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning text-dark",
            "Accepted" => "bg-info text-dark",
            "Started" => "bg-primary",
            "Completed" => "bg-success",
            "Paid" => "bg-success",
            "Cancelled" => "bg-danger",
            _ => "bg-dark"
        };
    }
}

<style>

    .myrides-title {
        color: #fff;
    }

    /* MOBILE FIX */
    @@media (max-width: 480px) {
        .myrides-table {
            display: none !important;
        }

        .myrides-mobile {
            display: block !important;
        }
    }

    /* LIST */
    .ride-row {
        background: rgba(255,255,255,0.04);
        border-radius: 14px;
        transition: 0.2s;
    }

        .ride-row:hover {
            background: rgba(255,255,255,0.06);
        }

    /* PREMIUM CARD */
    .ride-detail-card {
        background: linear-gradient(145deg, #0f172a, #020617);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.45);
        animation: slideFade 0.25s ease;
    }

    @@keyframes slideFade {
        from {
            opacity: 0;
            transform: translateY(-12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

</style>
@if (TempData["CashAlert"] != null)
{
    <div class="alert alert-warning border-0 shadow-sm fw-semibold">
        @TempData["CashAlert"]
    </div>
}
<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1 myrides-title">My Rides</h2>
            <small class="text-secondary">
                Track, manage and review all your booked rides
            </small>
        </div>

        <a asp-action="BookRide" class="btn btn-warning fw-semibold px-4">
            Book Ride
        </a>
    </div>

    <!-- 🔥 DETAIL CARD (TOP) -->
    @foreach (var ride in Model)
    {
        <div id="ride-@ride.Id" class="ride-detail-card d-none p-3 mb-3">

            <div class="d-flex justify-content-between align-items-start">

                <div class="fw-bold fs-5 text-light">
                    @ride.PickupLocation → @ride.DropLocation
                </div>

                <button class="btn btn-danger btn-sm rounded-circle px-2"
                        onclick="closeRide(@ride.Id)">
                    ✕
                </button>

            </div>

            <div class="d-flex justify-content-between align-items-center mt-2 mb-2">

                <span class="text-warning fw-bold fs-6">
                    ₹@ride.Fare
                </span>

                <span class="badge @GetRideBadge(ride.Status)">
                    @ride.Status
                </span>

            </div>

            <div class="small text-secondary">
                OTP: <span class="fw-semibold text-light">@ride.OTP</span>
            </div>

            <div class="small text-secondary">
                @ride.CreatedAt.ToString("dd MMM yyyy hh:mm tt")
            </div>

        </div>
    }

    <!-- DESKTOP TABLE -->
    <div class="card p-3 shadow-sm border-0 myrides-table">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead>
                    <tr>
                        <th>Pickup</th>
                        <th>Drop</th>
                        <th>Fare</th>
                        <th>Status</th>
                        <th>OTP</th>
                        <th>Date</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var ride in Model)
                    {
                        <tr>
                            <td>@ride.PickupLocation</td>
                            <td>@ride.DropLocation</td>
                            <td class="text-warning fw-semibold">₹@ride.Fare</td>

                            <td>

                                <div class="d-flex flex-column gap-2 align-items-start">

                                    <!-- STATUS -->
                                    <span class="badge @GetRideBadge(ride.Status)">
                                        @ride.Status
                                    </span>

                                    <!-- NAVIGATE -->
                                    @if (ride.Status == "Accepted" || ride.Status == "Started")
                                    {
                                        <a asp-action="TrackRide"
                                           asp-route-id="@ride.Id"
                                           class="btn btn-sm btn-warning text-dark fw-semibold px-3">
                                            Navigate
                                        </a>
                                    }

                                    <!-- PAYMENT -->
                                    @if (ride.Status == "Completed")
                                    {
                                        <a asp-controller="Payment"
                                           asp-action="Pay"
                                           asp-route-rideId="@ride.Id"
                                           class="btn btn-sm btn-warning fw-semibold px-3">
                                            Pay Now
                                        </a>
                                    }

                                </div>

                            </td>

                            <td>@ride.OTP</td>
                            <td>@ride.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

    <!-- MOBILE LIST -->
    <div class="myrides-mobile" style="display:none;">

        @foreach (var ride in Model)
        {
            <div class="ride-row d-flex justify-content-between align-items-center mb-3 p-3">

                <div class="fw-semibold text-light">
                    @ride.PickupLocation → @ride.DropLocation
                </div>

                <button class="btn btn-warning btn-sm rounded-circle px-2"
                        onclick="showRide(@ride.Id)">
                    i
                </button>

            </div>
        }

    </div>

</div>

@section Scripts {

    <script>

        function showRide(id) {
            document.querySelectorAll('.ride-detail-card')
                .forEach(x => x.classList.add('d-none'));

            document.getElementById('ride-' + id)
                .classList.remove('d-none');

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function closeRide(id) {
            document.getElementById('ride-' + id)
                .classList.add('d-none');
        }

    </script>

}