@model Ridex.Models.Ride

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Payment</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>

        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: radial-gradient(circle at top, #1e293b, #020617);
            color: #fff;
        }

        .payment-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .payment-card {
            width: 100%;
            max-width: 500px;
            backdrop-filter: blur(20px);
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 24px;
            padding: 28px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6);
            animation: fadeUp 0.4s ease;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .title {
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 4px;
        }

        .subtitle {
            color: #9ca3af;
            font-size: 13px;
            margin-bottom: 20px;
        }

        .route {
            background: rgba(255,255,255,0.04);
            padding: 16px;
            border-radius: 14px;
            margin-bottom: 20px;
        }

            .route div {
                margin-bottom: 6px;
            }

        .fare {
            text-align: center;
            font-size: 32px;
            font-weight: bold;
            color: #facc15;
            margin: 20px 0;
        }

        .methods {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .method {
            padding: 14px;
            border-radius: 14px;
            border: 1px solid rgba(255,255,255,0.08);
            cursor: pointer;
            transition: 0.25s;
        }

            .method:hover {
                transform: translateY(-2px);
                border-color: #facc15;
            }

            .method.active {
                background: rgba(250,204,21,0.1);
                border-color: #facc15;
            }

            .method i {
                margin-right: 10px;
            }

        .pay-btn {
            margin-top: 20px;
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 14px;
            font-size: 16px;
            font-weight: bold;
            background: linear-gradient(135deg, #facc15, #f59e0b);
            color: #000;
            cursor: pointer;
            transition: 0.3s;
        }

            .pay-btn:hover {
                transform: scale(1.03);
            }

    </style>

</head>

<body>

    <div class="payment-wrapper">

        <div class="payment-card">

            <div class="title">Complete Payment</div>
            <div class="subtitle">Secure & fast transaction</div>

            <div class="route">
                <div><b>Pickup:</b> @Model.PickupLocation</div>
                <div><b>Drop:</b> @Model.DropLocation</div>
            </div>

            <div class="fare">₹@Model.Fare</div>

            <form asp-action="PayNow" method="post" id="paymentForm">

                @Html.AntiForgeryToken()

                <input type="hidden" name="rideId" value="@Model.Id" />
                <input type="hidden" name="paymentMethod" id="paymentMethod" value="Cash" />

                <div class="methods">

                    <div class="method active" data-method="Cash">
                        <i class="fa-solid fa-money-bill-wave"></i> Cash
                    </div>

                    <div class="method" data-method="UPI">
                        <i class="fa-solid fa-mobile-screen-button"></i> UPI
                    </div>

                    <div class="method" data-method="Card">
                        <i class="fa-solid fa-credit-card"></i> Card
                    </div>

                </div>

                <button type="submit" class="pay-btn" id="payBtn">
                    Pay Now
                </button>

            </form>

        </div>

    </div>

    <script>

        const methods = document.querySelectorAll(".method");
        const paymentMethod = document.getElementById("paymentMethod");
        const payBtn = document.getElementById("payBtn");

        methods.forEach(m => {
            m.onclick = function () {

                methods.forEach(x => x.classList.remove("active"));
                this.classList.add("active");

                paymentMethod.value = this.dataset.method;
            };
        });

        document.getElementById("paymentForm").addEventListener("submit", function () {

            payBtn.innerHTML = "Processing...";
            payBtn.disabled = true;

        });

    </script>

</body>
</html>