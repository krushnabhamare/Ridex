@model List<Ridex.Models.ApplicationUser>

@{
    ViewData["Title"] = "Users";

    int totalUsers =
        Model?.Count ?? 0;

    int riders =
        Model?.Count(x =>
            x.RoleName == "Rider") ?? 0;

    int drivers =
        Model?.Count(x =>
            x.RoleName == "Driver") ?? 0;

    int admins =
        Model?.Count(x =>
            x.RoleName == "Admin") ?? 0;

    var orderedUsers =
        Model?
        .OrderBy(x =>
            x.RoleName == "Admin" ? 1 :
            x.RoleName == "Driver" ? 2 : 3)

        .ThenBy(x => x.FullName)

        .ToList()

        ?? new List<Ridex.Models.ApplicationUser>();
}

@functions {

    string GetRoleBadge(string role)
    {
        return role switch
        {
            "Admin" =>
                "bg-warning text-dark",

            "Driver" =>
                "bg-success",

            "Rider" =>
                "bg-primary",

            _ =>
                "bg-secondary"
        };
    }
}

<style>

    .role-filter-select {
        width: 160px;
    }

    .user-table-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #1e2a3a;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

</style>

<!-- STATS -->
<div class="row g-4 mb-4">

    <div class="col-md-6 col-xl-3">

        <div class="card p-4 h-100">

            <small class="text-secondary">
                Total Users
            </small>

            <h3 class="fw-bold mt-2">

                @totalUsers

            </h3>

            <small class="text-info">
                Registered
            </small>

        </div>

    </div>

    <div class="col-md-6 col-xl-3">

        <div class="card p-4 h-100">

            <small class="text-secondary">
                Riders
            </small>

            <h3 class="fw-bold mt-2">

                @riders

            </h3>

            <small class="text-primary">
                Customers
            </small>

        </div>

    </div>

    <div class="col-md-6 col-xl-3">

        <div class="card p-4 h-100">

            <small class="text-secondary">
                Drivers
            </small>

            <h3 class="fw-bold mt-2">

                @drivers

            </h3>

            <small class="text-success">
                Partners
            </small>

        </div>

    </div>

    <div class="col-md-6 col-xl-3">

        <div class="card p-4 h-100">

            <small class="text-secondary">
                Admins
            </small>

            <h3 class="fw-bold mt-2">

                @admins

            </h3>

            <small class="text-warning">
                System
            </small>

        </div>

    </div>

</div>

<!-- TABLE -->
<div class="card p-4">

    <!-- TOP -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <h4 class="fw-bold mb-0">

            User Management

        </h4>

        <div class="d-flex gap-2 flex-wrap">

            <!-- FILTER -->
            <select id="roleFilter"
                    class="form-select form-select-sm role-filter-select">

                <option value="All" style="color:black">
                    All Roles
                </option>

                <option value="Admin" style="color:black">
                    Admin
                </option>

                <option value="Driver" style="color:black">
                    Driver
                </option>

                <option value="Rider" style="color:black">
                    Rider
                </option>

            </select>

            <!-- COUNT -->
            <span class="badge bg-warning text-dark d-flex align-items-center px-3">

                @totalUsers Users

            </span>

        </div>

    </div>

    <!-- TABLE -->
    <div class="table-responsive">

        <table class="table table-hover align-middle mb-0"
               id="usersTable">

            <thead>

                <tr>

                    <th>User</th>

                 <th>Email</th>

                    <th>Phone</th>

                    <th>Role</th>

                </tr>

            </thead>

            <tbody>

                @if (orderedUsers.Any())
                {
                    @foreach (var user in orderedUsers)
                    {
                        <tr data-role="@user.RoleName">

                            <!-- NAME -->
                            <td>
                                <div class="d-flex align-items-center gap-3">

                                    @if (!string.IsNullOrEmpty(user.ProfilePhoto))
                                    {
                                        <img src="@user.ProfilePhoto"
                                             class="user-table-img" />
                                    }
                                    else
                                    {
                                        <div class="user-avatar">
                                            <i class="fa-solid fa-user"></i>
                                        </div>
                                    }

                                    <div>
                                        <div class="fw-semibold">
                                            @(user.FullName ?? "N/A")
                                        </div>

                                        <small class="text-secondary">
                                            @user.Email
                                        </small>
                                    </div>

                                </div>
                            </td>

                            <!-- EMAIL -->
                           <td>

                                @(user.Email ?? "N/A")

                            </td> 

                            <!-- PHONE -->
                            <td>

                                @(user.PhoneNumber ?? "N/A")

                            </td>

                            <!-- ROLE -->
                            <td>

                                <span class="badge @GetRoleBadge(user.RoleName)">

                                    @user.RoleName

                                </span>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="4"
                            class="text-center py-5">

                            <i class="fa-solid fa-users fa-2x mb-3 text-secondary"></i>

                            <div class="fw-semibold">

                                No users found

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section Scripts {

    <script>

        
        // Cached Elements
        

        const roleFilter =
            document.getElementById(
                "roleFilter");

        const rows =
            document.querySelectorAll(
                "#usersTable tbody tr");

        
        // Filter Logic
        

        roleFilter.addEventListener(
            "change",
            function () {

                const selected =
                    this.value;

                rows.forEach(row => {

                    const role =
                        row.getAttribute(
                            "data-role");

                    row.style.display =
                        selected === "All" ||
                        role === selected
                        ? ""
                        : "none";
                });
            });

    </script>
}